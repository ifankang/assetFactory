{
	"name": "assettemplatefactory",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000 --host 127.0.0.1",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@imgly/background-removal-node": "^1.4.5",
		"@neplex/vectorizer": "^0.1.0",
		"@xyflow/svelte": "^1.6.2",
		"image-q": "^4.0.0",
		"potrace": "^2.1.8",
		"sharp": "^0.35.3",
		"svgo": "^4.0.1"
	},
	"overrides": {
		"sharp": "$sharp"
	}
}
